---
const testimonials = [
  {
    name: 'İSMAİL DİNÇ',
    date: '13/09/2022',
    rating: 5,
    text: 'Usta deneyimli ve ilgili. İletişimi fevkalâde. Aracımın sorununu kısa sürede tespit edip uygun fiyata çözdüler. Kesinlikle tavsiye ederim.',
    avatar: 'İ',
    color: 'orange'
  },
  {
    name: 'Azim Özmen',
    date: '27/07/2022',
    rating: 5,
    text: 'Senelerdir gidiyorum usta işini iyi yapan biri ne zaman gitsem yardımcı olmuştur. Hem Hyundai hem Kia araçlarım için tek adresim.',
    avatar: 'A',
    color: 'blue'
  },
  {
    name: 'Müjdat DÖNE',
    date: '06/06/2022',
    rating: 5,
    text: 'İsah usta işini iyi yapan biri ne zaman gitsem yardımcı olmuştur. Dürüst esnaf bulmak zor bu devirde, gözünüz kapalı güvenebilirsiniz.',
    avatar: 'M',
    color: 'slate'
  },
  {
    name: 'Soner Kurban',
    date: 'Bir ay önce',
    rating: 5,
    text: 'Hemen müşterilerle ilgileniyorlar. Yaptıkları işi biliyorlar. Gayet güzel ve kaliteli çalışıyorlar. Fiyat olarak uygun bir işletme.',
    avatar: 'S',
    color: 'red'
  },
  {
    name: 'Metehan Aydoğan',
    date: 'Bir ay önce',
    rating: 5,
    text: 'Her şey için çok teşekkür ederim İsah ustam eline emeğine sağlık sizleri tanıdığıma çok memnun oldum kral adamsın saygılar sunarım.',
    avatar: 'M',
    color: 'slate'
  }
];
---

<section class="relative py-24 bg-slate-950" id="testimonials-section">
  <div class="container mx-auto px-4">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-24">
      
      <!-- STICKY LEFT PANEL -->
      <div class="lg:w-5/12 lg:h-[calc(100vh-6rem)] lg:sticky lg:top-24 flex flex-col justify-center mb-12 lg:mb-0">
        <div class="relative z-10" data-reveal="fade-up">
          <span class="text-orange-500 font-button tracking-[0.4em] uppercase text-[10px] mb-4 block">Müşteri Deneyimi</span>
          <h2 class="text-3xl md:text-5xl text-white mb-8 leading-tight font-hero-alt tracking-[0.1em] uppercase">
            SİZDEN GELEN <br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-orange-400">GÜZEL SÖZLER</span>
          </h2>
          
          <!-- Google Rating Card - Premium Glass -->
          <div class="bg-white/5 backdrop-blur-3xl rounded-[2.5rem] p-10 shadow-[0_50px_100px_-20px_rgba(0,0,0,0.5)] border border-white/10 inline-block max-w-sm">
            <div class="flex items-center gap-4 mb-4">
              <img src="https://cdn.cdnlogo.com/logos/g/35/google-icon.svg" alt="Google" class="w-8 h-8" />
              <span class="text-white font-button text-sm tracking-widest">Google Yorumları</span>
            </div>
            <div class="flex items-baseline gap-2 mb-2">
              <span class="text-5xl font-button text-white">4.4</span>
              <span class="text-slate-400 text-xs font-button tracking-widest">/ 5.0</span>
            </div>
            <div class="flex gap-1 mb-4">
              {[...Array(5)].map(() => (
                <svg class="w-6 h-6 text-yellow-400 fill-current" viewBox="0 0 20 20">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
              ))}
            </div>
            <p class="text-slate-400 text-sm">
              <strong class="text-white">40+</strong> gerçek müşteri değerlendirmesiyle Gebze'nin en güvenilir özel servisi.
            </p>
            
            <a 
              href="https://g.page/r/CZuq_JcIFA4TEAE/review" 
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex items-center gap-2 text-orange-500 font-bold text-sm hover:underline"
            >
              <span class="font-button tracking-widest">Bizi Değerlendirin</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
          </div>
        </div>
        
        <!-- Background Decoration -->
        <div class="absolute top-1/2 left-0 -translate-y-1/2 w-[500px] h-[500px] bg-gradient-to-br from-orange-500/10 to-blue-500/10 rounded-full blur-3xl -z-10 pointer-events-none"></div>
      </div>

      <!-- SCROLLABLE RIGHT PANEL (Testimonial Cards) -->
      <div class="lg:w-7/12 space-y-10 lg:py-24">
        {testimonials.map((item, index) => (
          <div class="testimonial-card group relative bg-white/5 backdrop-blur-2xl rounded-[2rem] p-10 md:p-12 shadow-2xl hover:shadow-[0_50px_100px_-20px_rgba(249,115,22,0.15)] transition-all duration-700 border border-white/5 opacity-50 scale-95 hover:scale-100 hover:opacity-100 hover:border-orange-500/20">
            <div class="flex items-start justify-between gap-4 mb-8">
              <div class="flex items-center gap-6">
                <div class={`w-16 h-16 rounded-2xl bg-${item.color}-500/10 text-${item.color}-400 flex items-center justify-center text-2xl font-button border border-${item.color}-500/20 shadow-xl`}>
                  {item.avatar}
                </div>
                <div>
                  <h3 class="text-white text-lg font-button tracking-widest uppercase">{item.name}</h3>
                  <span class="text-slate-500 text-[10px] font-button tracking-widest block mt-1">{item.date}</span>
                </div>
              </div>
              <div class="flex gap-1">
                {[...Array(item.rating)].map(() => (
                  <svg class="w-5 h-5 text-orange-500 fill-current" viewBox="0 0 20 20">
                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                  </svg>
                ))}
              </div>
            </div>
            
            <p class="text-slate-300 text-xl leading-relaxed font-sans font-medium italic opacity-90">
              "{item.text}"
            </p>
            
            <!-- Verified Badge -->
            <div class="absolute top-8 right-8 opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden md:flex items-center gap-1 text-green-400 bg-green-500/10 px-3 py-1 rounded-full text-xs font-bold border border-green-500/20">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
              Onaylı Yorum
            </div>
          </div>
        ))}
      </div>

      <!-- CTA After Reviews -->
      <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="tel:05336157835"
          class="flex items-center gap-3 bg-orange-600 hover:bg-orange-700 text-white font-bold px-8 py-4 rounded-2xl transition-all duration-300 shadow-lg shadow-orange-900/30 hover:-translate-y-1"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.15 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          <span class="font-button tracking-widest uppercase text-sm">Siz de Arayın — 0533 615 78 35</span>
        </a>
        <a
          href="https://wa.me/905336157835?text=Merhaba,%20servis%20hakkında%20bilgi%20almak%20istiyorum."
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 bg-white/5 border border-white/10 hover:border-green-500/40 text-white font-bold px-8 py-4 rounded-2xl transition-all duration-300 hover:-translate-y-1"
        >
          <svg class="w-5 h-5 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span class="font-button tracking-widest uppercase text-sm">WhatsApp'tan Yaz</span>
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const cards = document.querySelectorAll('.testimonial-card');

  cards.forEach((card) => {
    gsap.to(card, {
      scrollTrigger: {
        trigger: card,
        start: "top 75%", // Kart ekranın %75'ine geldiğinde başla
        end: "top 25%", // Kart ekranın %25'ine geldiğinde bitir
        toggleActions: "play reverse play reverse", // Aşağı/yukarı scroll'da animasyonu oynat/geri al
        scrub: true, // Scroll ile senkronize et
      },
      opacity: 1,
      scale: 1,
      boxShadow: "0 25px 50px -12px rgba(0, 0, 0, 0.15)",
      borderColor: "rgba(249, 115, 22, 0.3)", // Orange border on active
      duration: 0.5
    });
  });
</script>