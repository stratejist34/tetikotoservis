---
// LocalBusinessSchema.astro
// Bu bileşen artık sadece servis sayfaları için LocalBusiness şeması üretir.
// Blog yazıları için BlogPostingSchema.astro kullanılmalıdır.

interface Props {
  title: string;
  description: string;
  url: string;
  areaServed?: string; // Opsiyonel: Gebze, Tuzla vb.
  ratingValue?: number;
  ratingCount?: number;
}

const { title, description, url, areaServed, ratingValue, ratingCount } =
  Astro.props;

const baseSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Tetik Otomotiv",
  image: "https://hyundaiservisim.com/images/tetik-web-logo.webp",
  "@id": "https://hyundaiservisim.com/#localbusiness",
  url: url,
  telephone: "+905336157835",
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Aydıntepe, Tuzla Sanayi Sitesi No:117 B2 Blok",
    addressLocality: "Tuzla",
    addressRegion: "İstanbul",
    postalCode: "34903",
    addressCountry: "TR",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: "40.851401",
    longitude: "29.303651",
  },
  areaServed: areaServed
    ? {
        "@type": "City",
        name: areaServed,
      }
    : [
        { "@type": "City", name: "Tuzla" },
        { "@type": "City", name: "Pendik" },
        { "@type": "City", name: "Gebze" },
        { "@type": "City", name: "Kurtköy" },
      ],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "09:00",
      closes: "18:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Saturday",
      opens: "09:00",
      closes: "17:00",
    },
  ],
  sameAs: ["https://maps.app.goo.gl/X7V55b5pZdPXJCqJA"],
};

const serviceSchema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: title,
  name: title,
  description,
  url,
  provider: {
    "@type": "LocalBusiness",
    "@id": "https://hyundaiservisim.com/#localbusiness",
    name: "Tetik Otomotiv",
  },
  areaServed: baseSchema.areaServed,
};

if (typeof ratingValue === "number" && typeof ratingCount === "number") {
  serviceSchema.aggregateRating = {
    "@type": "AggregateRating",
    ratingValue,
    reviewCount: ratingCount,
    bestRating: 5,
    worstRating: 1,
  };
}

const schemaPayload = [baseSchema, serviceSchema];
---

<script type="application/ld+json" set:html={JSON.stringify(schemaPayload)} />
