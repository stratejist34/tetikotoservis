---
/**
 * QuickActionBar — Hibrit CTA Sistemi (v2: Zero-Friction + Region Modal)
 *
 * 📊 Özellikler:
 * - Masaüstü: Hero altında statik, prestijli 3-buton barı
 * - Mobil: Dinamik hub (Telefon/WhatsApp)
 * - Region Modal: Tuzla/Gebze/Pendik filtresi (Intentional Friction)
 * - GPU Optimised: transform/opacity bazlı akıcı animasyonlar
 * - GA4: Detaylı etkinlik izleme
 */
---

<!-- DESKTOP BAR: Sadece masaüstü ve tabletlerde görünür -->
<div
    id="quick-action-bar-desktop"
    class="hidden md:block relative z-40 bg-slate-950/90 backdrop-blur-2xl border-y border-white/10"
>
    <div class="container mx-auto px-4 py-5">
        <div class="flex items-center justify-center gap-8">
            <!-- Motor Arızası -->
            <a
                href="https://wa.me/905336157835?text=Merhaba,%20aracımda%20bir%20arıza%20uyarısı%20var,%20arıza%20tespiti%20için%20randevu/bilgi%20almak%20istiyorum."
                target="_blank"
                class="quick-action-item group relative flex items-center gap-4 px-8 py-3.5 rounded-2xl bg-slate-900/60 border border-orange-500/40 hover:border-orange-500/80 transition-all duration-500 hover:-translate-y-1.5"
                data-action="Motor Arızası"
            >
                <div
                    class="w-11 h-11 bg-orange-500/30 rounded-xl flex items-center justify-center border border-orange-500/40 group-hover:scale-110 transition-all"
                >
                    <svg
                        class="w-6 h-6 text-orange-400"
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
                        ></path>
                    </svg>
                </div>
                <div class="flex flex-col items-start leading-tight">
                    <span
                        class="text-[10px] text-orange-400 font-button tracking-[0.2em] uppercase mb-0.5"
                        >ARIZA TESPİT</span
                    >
                    <span
                        class="text-sm font-button tracking-widest text-white font-bold uppercase"
                        >Motor Arızası</span
                    >
                </div>
            </a>

            <!-- Periyodik Bakım -->
            <a
                href="https://wa.me/905336157835?text=Merhaba,%20aracımın%20periyodik%20bakımı%20(yağ/filtre)%20için%20fiyat%20ve%20randevu%20bilgisi%20alabilir%20miyim?"
                target="_blank"
                class="quick-action-item group relative flex items-center gap-4 px-8 py-3.5 rounded-2xl bg-slate-900/60 border border-blue-500/40 hover:border-blue-500/80 transition-all duration-500 hover:-translate-y-1.5"
                data-action="Periyodik Bakım"
            >
                <div
                    class="w-11 h-11 bg-blue-500/30 rounded-xl flex items-center justify-center border border-blue-500/40 group-hover:scale-110 transition-all"
                >
                    <svg
                        class="w-6 h-6 text-blue-400"
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"
                        ></path>
                        <line x1="16" y1="8" x2="2" y2="22"></line>
                        <line x1="17.5" y1="15" x2="9" y2="15"></line>
                    </svg>
                </div>
                <div class="flex flex-col items-start leading-tight">
                    <span
                        class="text-[10px] text-blue-400 font-button tracking-[0.2em] uppercase mb-0.5"
                        >FULL KONTROL</span
                    >
                    <span
                        class="text-sm font-button tracking-widest text-white font-bold uppercase"
                        >Periyodik Bakım</span
                    >
                </div>
            </a>

            <!-- Hemen Sor -->
            <a
                href="tel:05336157835"
                class="quick-action-item group relative flex items-center gap-4 px-8 py-3.5 rounded-2xl bg-slate-900/60 border border-green-500/40 hover:border-green-500/80 transition-all duration-500 hover:-translate-y-1.5"
                data-action="Hemen Sor"
            >
                <div
                    class="w-11 h-11 bg-green-500/30 rounded-xl flex items-center justify-center border border-green-500/40 group-hover:scale-110 transition-all"
                >
                    <svg
                        class="w-6 h-6 text-green-400"
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                        ></path>
                    </svg>
                </div>
                <div class="flex flex-col items-start leading-tight">
                    <span
                        class="text-[10px] text-green-400 font-button tracking-[0.2em] uppercase mb-0.5"
                        >USTAYA BAĞLAN</span
                    >
                    <span
                        class="text-sm font-button tracking-widest text-white font-bold uppercase"
                        >Hemen Sor</span
                    >
                </div>
            </a>
        </div>
    </div>
</div>

<!-- MOBILE HUB: Sadece mobil ve küçük tabletlerde görünür -->
<div id="quick-action-hub-mobile" class="md:hidden">
    <!-- Dynamic Tooltip (Konuşma Balonu) - SOLDA -->
    <div
        id="hub-tooltip"
        class="fixed left-5 bottom-24 z-[1000] opacity-0 translate-y-4 transition-all duration-500 pointer-events-none"
    >
        <div
            class="relative bg-white text-slate-900 px-4 py-2 rounded-2xl shadow-xl font-bold text-xs whitespace-nowrap"
        >
            <span id="tooltip-text">Hemen Ara - 30 sn'de bağlan</span>
            <!-- Tooltip Oku -->
            <div class="absolute -bottom-2 left-6 w-4 h-4 bg-white rotate-45">
            </div>
        </div>
    </div>

    <!-- LEFT: Primary Phone Pill -->
    <a
        id="hub-trigger"
        href="tel:05336157835"
        class="fixed left-5 bottom-6 z-[1000] flex items-center gap-3 bg-gradient-to-r from-amber-500 to-orange-600 text-white px-6 py-4 rounded-full shadow-lg shadow-orange-950/40 no-underline"
        aria-label="Hemen Ara, Ustaya Bağlan"
    >
        <!-- Glossy Parlama Efekti -->
        <span
            class="absolute inset-0 rounded-full bg-gradient-to-t from-white/20 to-transparent opacity-50"
        ></span>

        <svg
            class="w-6 h-6 phone-ring"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
        </svg>

        <!-- CTA Text -->
        <span
            class="font-bold text-sm tracking-wide whitespace-nowrap hub-text-open"
            >HEMEN ARA</span
        >
    </a>

    <!-- RIGHT: Direct WhatsApp Button — Direkt wa.me linki (Interception Modal ile) -->
    <a
        id="hub-whatsapp-btn"
        href="https://wa.me/905336157835?text=Merhaba,%20servis%20hizmetleri%20hakkında%20bilgi%20almak%20istiyorum."
        target="_blank"
        rel="noopener noreferrer"
        class="fixed right-5 bottom-6 z-[1000] w-14 h-14 bg-[#25D366] text-white flex items-center justify-center rounded-full shadow-lg shadow-green-950/40 transition-transform active:scale-90 no-underline"
        aria-label="WhatsApp'tan Yaz"
    >
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
            <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
        </svg>
    </a>
</div>

<!-- Region & Service Warning Modal -->
<div
    id="region-modal"
    class="fixed inset-0 z-[99999] hidden"
    role="dialog"
    aria-modal="true"
>
    <!-- Backdrop -->
    <div
        id="modal-backdrop"
        class="absolute inset-0 bg-slate-950/90 backdrop-blur-sm transition-opacity duration-300 opacity-0"
    >
    </div>

    <!-- Modal Content -->
    <div
        class="absolute inset-x-4 top-1/2 -translate-y-1/2 flex flex-col items-center justify-center pointer-events-none"
    >
        <div
            id="modal-content"
            class="w-full max-w-sm bg-[#0f172a] border border-white/10 rounded-3xl shadow-2xl overflow-hidden transform transition-all duration-300 scale-90 opacity-0 pointer-events-auto relative"
        >
            <!-- Close Button -->
            <button
                id="modal-close-xf"
                class="absolute top-4 right-4 z-10 text-slate-400 hover:text-white p-2"
            >
                <svg
                    class="w-6 h-6"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>

            <!-- Icon -->
            <div class="pt-8 pb-4 flex justify-center">
                <div
                    class="w-20 h-20 rounded-full bg-red-900/20 flex items-center justify-center ring-4 ring-red-900/10"
                >
                    <svg
                        class="w-10 h-10 text-red-500"
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path
                            d="M12 22s-8-10.5-8-15a8 8 0 0 1 16 0c0 4.5-8 15-8 15z"
                        ></path>
                        <circle cx="12" cy="7" r="3"></circle>
                    </svg>
                </div>
            </div>

            <div class="px-6 pb-2 text-center">
                <h3 class="text-xl font-bold text-white mb-2">
                    Önemli Bilgilendirme
                </h3>
                <p class="text-slate-400 text-sm leading-relaxed px-2">
                    Hizmet bölgemiz sadece <strong class="text-white"
                        >Tuzla - Gebze - Pendik</strong
                    > ve çevresidir.
                </p>
            </div>

            <!-- Private Service Warning -->
            <div class="px-6 py-6">
                <div
                    class="bg-white/5 border border-white/10 rounded-2xl p-4 text-center"
                >
                    <p class="text-xs text-slate-400 mb-1">
                        İşletmemiz markadan bağımsız
                    </p>
                    <p
                        class="text-lg font-bold text-red-500 tracking-wide uppercase"
                    >
                        ÖZEL SERVİSTİR
                    </p>
                    <p class="text-[10px] text-slate-500 mt-1">
                        (Yetkili Servis Değildir)
                    </p>
                </div>
            </div>

            <!-- Actions -->
            <div class="px-6 pb-8 space-y-3">
                <a
                    id="modal-call-btn"
                    href="tel:05336157835"
                    class="w-full flex items-center justify-center gap-3 bg-red-600 hover:bg-red-700 text-white font-bold py-4 rounded-xl transition-all active:scale-95 shadow-lg shadow-red-900/20"
                >
                    <svg
                        class="w-5 h-5 phone-ring"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                        ></path>
                    </svg>
                    Bölgedeyim, Hemen Ara
                </a>

                <button
                    id="modal-cancel-btn"
                    class="w-full py-3 text-slate-500 font-medium text-sm hover:text-white transition-colors"
                >
                    Vazgeç
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function initQuickActionHub() {
        const hubContainer = document.getElementById("quick-action-hub-mobile");
        const triggerPhone = document.getElementById(
            "hub-trigger",
        ) as HTMLAnchorElement;
        const triggerWhatsapp = document.getElementById(
            "hub-whatsapp-btn",
        ) as HTMLAnchorElement;

        const modal = document.getElementById("region-modal");
        const backdrop = document.getElementById("modal-backdrop");
        const content = document.getElementById("modal-content");
        const closeX = document.getElementById("modal-close-xf");
        const cancelBtn = document.getElementById("modal-cancel-btn");
        const callBtn = document.getElementById("modal-call-btn");

        let currentAction = "phone";
        let modalHistoryPushed = false;

        function getHourSlot() {
            const externalHelper = (window as any).__tetikHourSlot;
            if (typeof externalHelper === "function") {
                return externalHelper();
            }
            const now = new Date(
                new Date().toLocaleString("en-US", {
                    timeZone: "Europe/Istanbul",
                }),
            );
            const minutes = now.getHours() * 60 + now.getMinutes();
            if (minutes < 8 * 60 + 30) return "pre_open";
            if (minutes < 14 * 60) return "open_morning";
            if (minutes < 20 * 60) return "open_evening";
            return "after_hours";
        }

        function trackEvent(
            eventKey: string,
            payload: Record<string, any> = {},
        ) {
            const helper = (window as any).__tetikTrackEvent;
            if (typeof helper === "function") {
                helper(eventKey, payload);
            } else if (typeof (window as any).gtag === "function") {
                // @ts-ignore
                (window as any).gtag("event", eventKey, payload);
            }
        }

        // Persistence check
        if (
            typeof sessionStorage !== "undefined" &&
            sessionStorage.getItem("region_dismissed") === "true"
        ) {
            if (hubContainer) hubContainer.classList.add("force-hidden");
        }

        function dismissForSession() {
            if (typeof sessionStorage !== "undefined") {
                sessionStorage.setItem("region_dismissed", "true");
            }
            closeModal();

            if (hubContainer) {
                hubContainer.style.pointerEvents = "none";
                hubContainer.style.transition =
                    "opacity 0.5s ease, transform 0.5s ease";
                hubContainer.style.opacity = "0";
                hubContainer.style.transform = "translateY(20px)";

                setTimeout(() => {
                    hubContainer.classList.add("force-hidden");
                }, 500);
            }

            trackEvent("cta_dismiss", {
                channel: currentAction,
                location: "quick_action_hub",
                reason: "user_cancelled_modal_session",
            });
        }

        function openModal(source = "phone", destinationUrl = null) {
            if (!modal || !backdrop || !content) {
                if (destinationUrl) window.location.href = destinationUrl;
                return;
            }

            currentAction = source;

            // Update Button Text & Link
            if (callBtn) {
                if (source === "whatsapp") {
                    callBtn.innerHTML = `
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
                        Bölgedeyim, Mesaj Yaz
                    `;
                    callBtn.classList.remove(
                        "bg-red-600",
                        "hover:bg-red-700",
                        "shadow-red-900/20",
                    );
                    callBtn.classList.add(
                        "bg-[#25D366]",
                        "hover:bg-[#128C7E]",
                        "shadow-[#25D366]/20",
                    );
                    callBtn.setAttribute(
                        "href",
                        destinationUrl || "https://wa.me/905336157835",
                    );
                } else {
                    callBtn.innerHTML = `
                        <svg class="w-5 h-5 phone-ring" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                        Bölgedeyim, Hemen Ara
                    `;
                    callBtn.classList.remove(
                        "bg-[#25D366]",
                        "hover:bg-[#128C7E]",
                        "shadow-[#25D366]/20",
                    );
                    callBtn.classList.add(
                        "bg-red-600",
                        "hover:bg-red-700",
                        "shadow-red-900/20",
                    );
                    callBtn.setAttribute(
                        "href",
                        destinationUrl || "tel:05336157835",
                    );
                }
            }

            modal.classList.remove("hidden");
            void modal.offsetWidth;
            backdrop.classList.remove("opacity-0");
            content.classList.remove("scale-90", "opacity-0");
            content.classList.add("scale-100", "opacity-100");
            document.body.style.overflow = "hidden";

            modalHistoryPushed = true;
            window.history.pushState({ modalOpen: true }, "");

            trackEvent("cta_intent", {
                channel: source,
                location: "quick_action_hub_modal",
            });
        }

        (window as any).openServiceRegionModal = openModal;

        function closeModal() {
            if (!modal || !backdrop || !content) return;
            backdrop.classList.add("opacity-0");
            content.classList.remove("scale-100", "opacity-100");
            content.classList.add("scale-90", "opacity-0");
            setTimeout(() => {
                modal.classList.add("hidden");
                document.body.style.overflow = "";
            }, 300);
        }

        window.addEventListener("popstate", (e) => {
            if (
                modal &&
                !modal.classList.contains("hidden") &&
                modalHistoryPushed
            ) {
                modalHistoryPushed = false;
                closeModal();
            }
        });

        triggerPhone?.addEventListener("click", (e) => {
            e.preventDefault();
            openModal("phone", triggerPhone.href);
        });

        triggerWhatsapp?.addEventListener("click", (e) => {
            e.preventDefault();
            openModal("whatsapp", triggerWhatsapp.href);
        });

        closeX?.addEventListener("click", dismissForSession);
        cancelBtn?.addEventListener("click", dismissForSession);
        backdrop?.addEventListener("click", (e) => {
            if (e.target === backdrop) dismissForSession();
        });
        callBtn?.addEventListener("click", () => {
            trackEvent("cta_click", {
                channel: currentAction,
                location: "quick_action_hub_modal",
            });
            setTimeout(closeModal, 1000);
        });

        // Time logic: Primary by hour
        function applyPrimaryByHour() {
            if (!triggerPhone || !triggerWhatsapp) return;
            const slot = getHourSlot();
            const isBusinessHours =
                slot === "open_morning" || slot === "open_evening";
            const shouldHidePhone =
                slot === "pre_open" || slot === "after_hours";

            triggerPhone.classList.remove(
                "hub-primary",
                "hub-primary-phone",
                "hub-secondary",
            );
            triggerWhatsapp.classList.remove(
                "hub-primary",
                "hub-primary-whatsapp",
                "hub-secondary",
            );
            triggerPhone.classList.toggle("hidden", shouldHidePhone);

            const phoneText = triggerPhone.querySelector(".hub-text-open");

            if (isBusinessHours) {
                triggerPhone.classList.add("hub-primary", "hub-primary-phone");
                triggerWhatsapp.classList.add("hub-secondary");
                if (phoneText) phoneText.textContent = "HEMEN ARA";
            } else {
                triggerWhatsapp.classList.add(
                    "hub-primary",
                    "hub-primary-whatsapp",
                );
                triggerPhone.classList.add("hub-secondary");
                if (phoneText) phoneText.textContent = "MESAI SAATINDE ARA";
            }
            return isBusinessHours;
        }

        const isBusinessHours = applyPrimaryByHour();

        triggerPhone?.addEventListener("click", () => {
            trackEvent("cta_click", {
                channel: "phone",
                location: "quick_action_hub",
            });
        });

        triggerWhatsapp?.addEventListener("click", () => {
            trackEvent("cta_click", {
                channel: "whatsapp",
                location: "quick_action_hub",
            });
        });

        // Tooltip system
        const tooltip = document.getElementById("hub-tooltip");
        const tooltipText = document.getElementById("tooltip-text");
        const slotMessageHelper = (window as any).__tetikSlotMessage;
        const slotPrimaryMessage =
            typeof slotMessageHelper === "function"
                ? slotMessageHelper()
                : isBusinessHours
                  ? "Su an: Hizli baglanti saati"
                  : "Su an: Yarin planlamasi acik";
        const activePhrases = isBusinessHours
            ? [
                  "Hemen Ara - 30 sn'de bağlan",
                  "WhatsApp'tan Fiyat Al",
                  slotPrimaryMessage,
              ]
            : [
                  "WhatsApp'tan Yaz - Sabah dönelim",
                  slotPrimaryMessage,
                  "Tuzla - Gebze Ozel Servis",
              ];

        function showTooltip(index: number, duration = 3000) {
            if (!tooltip || !tooltipText) return;
            tooltipText.textContent = activePhrases[index];
            tooltip.classList.remove("opacity-0", "translate-y-4");
            tooltip.classList.add("opacity-100", "translate-y-0");
            setTimeout(() => {
                tooltip.classList.add("opacity-0", "translate-y-4");
                tooltip.classList.remove("opacity-100", "translate-y-0");
            }, duration);
        }

        setTimeout(() => showTooltip(0), 10000);
        setTimeout(() => showTooltip(1), 21000);
        setTimeout(() => showTooltip(2), 46000);

        // Scroll glow
        let glowFired = false;
        window.addEventListener(
            "scroll",
            () => {
                if (glowFired) return;
                const scrollPercent =
                    window.scrollY /
                    (document.documentElement.scrollHeight -
                        window.innerHeight);
                if (scrollPercent > 0.6) {
                    glowFired = true;
                    const primaryBtn = isBusinessHours
                        ? triggerPhone
                        : triggerWhatsapp;
                    if (primaryBtn) {
                        primaryBtn.classList.add("glow-burst");
                        setTimeout(
                            () => primaryBtn.classList.remove("glow-burst"),
                            600,
                        );
                    }
                }
            },
            { passive: true },
        );

        // Conflict detection: hide sticky hub when another CTA block is on screen
        const conflictTargets = document.querySelectorAll(
            "[data-sticky-conflict]",
        );
        if (hubContainer && conflictTargets.length > 0) {
            const conflictObserver = new IntersectionObserver(
                (entries) => {
                    const hasVisibleConflict = entries.some(
                        (entry) => entry.isIntersecting,
                    );
                    hubContainer.classList.toggle(
                        "is-conflicted",
                        hasVisibleConflict,
                    );
                },
                { threshold: 0.2 },
            );
            conflictTargets.forEach((target) =>
                conflictObserver.observe(target),
            );
        }
    }

    initQuickActionHub();
    document.addEventListener("astro:page-load", initQuickActionHub);
</script>

<style>
    #quick-action-hub-mobile.force-hidden {
        display: none !important;
    }

    #quick-action-hub-mobile.is-conflicted {
        opacity: 0;
        pointer-events: none;
        transform: translateY(18px);
        transition:
            opacity 0.3s ease,
            transform 0.3s ease;
    }
    #quick-action-bar-desktop {
        box-shadow: 0 15px 40px -10px rgba(0, 0, 0, 0.7);
    }

    /* v2: GPU Pulse */
    .hub-primary::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        z-index: -1;
    }
    .hub-primary-phone::after {
        background-color: rgba(245, 158, 11, 0.4);
        animation: pulse-ring-gpu 2.8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    .hub-primary-whatsapp::after {
        background-color: rgba(37, 211, 102, 0.4);
        animation: pulse-ring-gpu 2.8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        animation-delay: 0.5s;
    }

    @keyframes pulse-ring-gpu {
        0% {
            transform: scale(1);
            opacity: 0.8;
        }
        80%,
        100% {
            transform: scale(1.6);
            opacity: 0;
        }
    }

    .hub-primary {
        transform: scale(1.06);
        opacity: 1;
    }
    .hub-secondary {
        transform: scale(1);
        opacity: 0.88;
    }

    @keyframes glow-burst-anim {
        0% {
            transform: scale(1);
            filter: brightness(1);
        }
        50% {
            transform: scale(1.15);
            filter: brightness(1.3);
        }
        100% {
            transform: scale(1);
            filter: brightness(1);
        }
    }
    .glow-burst {
        animation: glow-burst-anim 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
    }

    @keyframes phone-ring-animation {
        0% {
            transform: rotate(0);
        }
        5% {
            transform: rotate(15deg);
        }
        10% {
            transform: rotate(-15deg);
        }
        15% {
            transform: rotate(15deg);
        }
        20% {
            transform: rotate(-15deg);
        }
        25% {
            transform: rotate(10deg);
        }
        30% {
            transform: rotate(-10deg);
        }
        100% {
            transform: rotate(0);
        }
    }
    .phone-ring {
        animation: phone-ring-animation 4s infinite;
    }
    .no-underline {
        text-decoration: none !important;
    }
</style>
