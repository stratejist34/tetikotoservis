---
import { serviceScope } from "../lib/serviceScope";

/**
 * QuickActionBar — Hibrit CTA Sistemi (v2: Zero-Friction + Region Modal)
 *
 * 📊 Özellikler:
 * - Masaüstü: Hero altında statik, prestijli 3-buton barı
 * - Mobil: Dinamik hub (Telefon/WhatsApp)
 * - Region Modal: Tuzla/Pendik/Gebze/Kurtkoy filtresi (Intentional Friction)
 * - GPU Optimised: transform/opacity bazlı akıcı animasyonlar
 * - GA4: Detaylı etkinlik izleme
 */
const phoneHref = `tel:${serviceScope.phone}`;
const modalRegionText = serviceScope.regions.join(" - ");
const modalRegionListText = serviceScope.regions.join(", ");
const waMessageAriza = encodeURIComponent(
  "Merhaba, aracımda bir arıza uyarısı var, arıza tespiti için randevu/bilgi almak istiyorum.",
);
const waMessageBakim = encodeURIComponent(
  "Merhaba, aracımın periyodik bakımı (yağ/filtre) için fiyat ve randevu bilgisi alabilir miyim?",
);
const waMessageGenel = encodeURIComponent(
  "Merhaba, servis hizmetleri hakkında bilgi almak istiyorum.",
);
const waArizaHref = `https://wa.me/${serviceScope.whatsappNumber}?text=${waMessageAriza}`;
const waBakimHref = `https://wa.me/${serviceScope.whatsappNumber}?text=${waMessageBakim}`;
const waGenelHref = `https://wa.me/${serviceScope.whatsappNumber}?text=${waMessageGenel}`;
---

<!-- MOBILE HUB: Sadece mobil ve küçük tabletlerde görünür -->
<div id="quick-action-hub-mobile" class="md:hidden">
    <!-- Dynamic Tooltip (Konuşma Balonu) - SOLDA -->
    <div
        id="hub-tooltip"
        class="fixed left-5 bottom-24 z-[1000] opacity-0 translate-y-4 transition-all duration-500 pointer-events-none"
    >
        <div
            class="relative bg-white text-slate-900 px-4 py-2 rounded-2xl shadow-xl font-bold text-xs whitespace-nowrap"
        >
            <span id="tooltip-text">Hemen Ara - 30 sn'de bağlan</span>
            <!-- Tooltip Oku -->
            <div class="absolute -bottom-2 left-6 w-4 h-4 bg-white rotate-45">
            </div>
        </div>
    </div>

    <!-- LEFT: Primary Phone Pill -->
    <a
        id="hub-trigger"
        href={phoneHref}
        class="fixed left-5 bottom-6 z-[1000] flex items-center gap-3 bg-gradient-to-r from-amber-500 to-orange-600 text-white px-6 py-4 rounded-full shadow-lg shadow-orange-950/40 no-underline"
        aria-label="Hemen Ara, Ustaya Bağlan"
    >
        <!-- Glossy Parlama Efekti -->
        <span
            class="absolute inset-0 rounded-full bg-gradient-to-t from-white/20 to-transparent opacity-50"
        ></span>

        <svg
            class="w-6 h-6 phone-ring"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
        </svg>

        <!-- CTA Text -->
        <span
            class="font-bold text-sm tracking-wide whitespace-nowrap hub-text-open"
            >HEMEN ARA</span
        >
    </a>

    <!-- RIGHT: Direct WhatsApp Button — Direkt wa.me linki (Interception Modal ile) -->
    <a
        id="hub-whatsapp-btn"
        href={waGenelHref}
        target="_blank"
        rel="noopener noreferrer"
        class="fixed right-5 bottom-6 z-[1000] flex items-center gap-2 bg-[#25D366] text-white px-5 py-4 rounded-full shadow-lg shadow-green-950/40 transition-transform active:scale-90 no-underline"
        aria-label="WhatsApp'tan Yaz"
    >
        <svg class="w-6 h-6 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
        </svg>
        <span class="font-bold text-sm tracking-wide whitespace-nowrap">MESAJ YAZ</span>
    </a>
</div>

<!-- Region & Service Warning Modal -->
<div
    id="region-modal"
    class="fixed inset-0 z-[99999] hidden"
    role="dialog"
    aria-modal="true"
>
    <!-- Backdrop -->
    <div
        id="modal-backdrop"
        class="absolute inset-0 bg-slate-950/90 backdrop-blur-sm transition-opacity duration-300 opacity-0"
    >
    </div>

    <!-- Modal Content -->
    <div
        class="absolute inset-x-4 top-1/2 -translate-y-1/2 flex flex-col items-center justify-center pointer-events-none"
    >
        <div
            id="modal-content"
            class="w-full max-w-sm bg-slate-900 border-2 border-red-600 rounded-3xl shadow-2xl overflow-hidden transform transition-all duration-300 scale-90 opacity-0 pointer-events-auto relative shadow-[0_0_50px_rgba(220,38,38,0.3)]"
        >
            <!-- Dikkat Header -->
            <div class="bg-red-600 py-3 text-center">
                <p class="text-white font-black text-xl tracking-[0.2em] uppercase flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                    DİKKAT
                </p>
            </div>

            <!-- Content Area -->
            <div class="px-6 pt-8 pb-2 text-center">
                <h3 class="text-2xl font-black text-white mb-4 leading-tight">
                    SADECE <br/>
                    <span class="text-amber-400 text-3xl">İSTANBUL (ANADOLU)</span> <br/>
                    VE <span class="text-amber-400 text-3xl">GEBZE</span> <br/>
                    BÖLGESİNE HİZMET VERİYORUZ!
                </h3>
            </div>

            <!-- Private Service Warning -->
            <div class="px-6 py-4">
                <div
                    class="bg-white/5 border-2 border-slate-700/50 rounded-2xl p-4 text-center"
                >
                    <p class="text-sm font-medium text-slate-300 mb-1">
                        Şehir dışından aramayınız.
                    </p>
                    <p
                        class="text-xl font-black text-red-500 tracking-wide uppercase"
                    >
                        YETKİLİ SERVİS DEĞİLİZ
                    </p>
                    <p class="text-xs text-slate-400 mt-2 font-medium">
                        Tüm randevular için bölge teyidi zorunludur.
                    </p>
                </div>
            </div>

            <!-- Actions -->
            <div class="px-6 pb-8 space-y-3">
                <a
                    id="modal-confirm-btn"
                    href={phoneHref}
                    class="w-full flex flex-col items-center justify-center gap-1 bg-green-600 hover:bg-green-700 text-white font-black text-lg py-4 rounded-xl transition-all active:scale-95 shadow-[0_5px_20px_rgba(22,163,74,0.4)] border border-green-500"
                >
                    <div class="flex items-center gap-2">
                        <svg
                            class="w-6 h-6 phone-ring"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2.5"
                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            ></path>
                        </svg>
                        EVET, İSTANBUL VEYA GEBZE'DEYİM
                    </div>
                </a>

                <button
                    id="modal-reject-btn"
                    class="w-full flex items-center justify-center gap-2 py-3.5 rounded-xl border-2 border-slate-700 text-slate-300 font-bold text-sm bg-slate-800/50 hover:bg-slate-800 hover:border-slate-500 hover:text-white transition-colors"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    HAYIR, BAŞKA İLDEYİM
                </button>

            </div>
        </div>
    </div>
</div>

<script define:vars={{ phoneHref, waGenelHref }}>
    function initQuickActionHub() {
        const hubContainer = document.getElementById("quick-action-hub-mobile");
        const triggerPhone = document.getElementById(
            "hub-trigger",
        );
        const triggerWhatsapp = document.getElementById(
            "hub-whatsapp-btn",
        );

        // Outer-scope modal ref for popstate/desktop-bar checks (openModal/closeModal re-query fresh)
        let modal = document.getElementById("region-modal");
        const rejectBtn = document.getElementById("modal-reject-btn");
        const confirmBtn = document.getElementById("modal-confirm-btn");

        let currentAction = "phone";
        let currentLocation = "quick_action_hub";
        let currentMeta = {};
        let modalHistoryPushed = false;

        function getHourSlot() {
            const externalHelper = window.__tetikHourSlot;
            if (typeof externalHelper === "function") {
                return externalHelper();
            }
            const now = new Date(
                new Date().toLocaleString("en-US", {
                    timeZone: "Europe/Istanbul",
                }),
            );
            const minutes = now.getHours() * 60 + now.getMinutes();
            if (minutes < 8 * 60 + 30) return "pre_open";
            if (minutes < 14 * 60) return "open_morning";
            if (minutes < 18 * 60) return "open_evening";
            return "after_hours";
        }

        function trackEvent(
            eventKey,
            payload = {},
        ) {
            const helper = window.__tetikTrackEvent;
            if (typeof helper === "function") {
                helper(eventKey, payload);
            } else if (typeof window.gtag === "function") {
                window.gtag("event", eventKey, payload);
            }
        }

        function isQualifiedSession() {
            return (
                typeof sessionStorage !== "undefined" &&
                sessionStorage.getItem("region_modal_qualified") === "true"
            );
        }

        function setQualifiedSession() {
            if (typeof sessionStorage !== "undefined") {
                sessionStorage.setItem("region_modal_qualified", "true");
            }
        }

        function trackQualifiedContact(
            source = "phone",
            location = "page",
            channel = "direct",
            meta = {},
        ) {
            const locationTag = `${location}_${channel}`;
            trackEvent(
                source === "phone"
                    ? "qualified_phone_call"
                    : "qualified_whatsapp_click",
                { ...meta, location: locationTag },
            );

            // Backward compatibility events
            trackEvent(
                source === "phone" ? "telefon_aramasi" : "whatsapptan_yazanlar",
                { ...meta, location: locationTag },
            );
        }

        function getScrollDepthPct() {
            const helper = window.__tetikScrollDepthPct;
            if (typeof helper === "function") return helper();
            const scrollable =
                document.documentElement.scrollHeight - window.innerHeight;
            if (scrollable <= 0) return 0;
            return Math.max(
                0,
                Math.min(100, Math.round((window.scrollY / scrollable) * 100)),
            );
        }

        function dismissModalByChoice(reason = "cancelled") {
            closeModal();

            trackEvent("region_filter_rejected", {
                location: currentLocation,
                source: currentAction,
                reason,
                ...currentMeta,
            });

            // Backward compatibility events
            trackEvent(
                currentAction === "phone" ? "tel_vazgecti" : "whatsapp_vazgecti",
                { location: currentLocation, ...currentMeta },
            );
        }

        function openModal(
            source = "phone",
            destinationUrl = null,
            location = "quick_action_hub",
            meta = {},
        ) {
            // Fresh DOM queries every call — avoids stale refs if init ran before DOM was ready
            const modal = document.getElementById("region-modal");
            const backdrop = document.getElementById("modal-backdrop");
            const content = document.getElementById("modal-content");
            const confirmBtn = document.getElementById("modal-confirm-btn");

            // Qualified sessions bypass modal directly.
            if (isQualifiedSession()) {
                trackQualifiedContact(source, location, "direct", meta);
                if (destinationUrl) {
                    if (source === "whatsapp") {
                        window.open(destinationUrl, "_blank");
                    } else {
                        window.location.href = destinationUrl;
                    }
                }
                return;
            }

            if (!modal || !backdrop || !content) {
                if (destinationUrl) window.location.href = destinationUrl;
                return;
            }

            currentAction = source;
            currentLocation = location;
            currentMeta = meta || {};

            // Update Button Text & Link
            if (confirmBtn) {
                if (source === "whatsapp") {
                    confirmBtn.innerHTML = `
                        <div class="flex items-center gap-2">
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
                        EVET, İSTANBUL VEYA GEBZE'DEYİM
                        </div>
                    `;
                    confirmBtn.classList.remove(
                        "bg-green-600",
                        "hover:bg-green-700",
                        "shadow-[0_5px_20px_rgba(22,163,74,0.4)]",
                        "border",
                        "border-green-500",
                    );
                    confirmBtn.classList.add(
                        "bg-[#25D366]",
                        "hover:bg-[#128C7E]",
                        "shadow-[0_5px_20px_rgba(37,211,102,0.4)]",
                        "border",
                        "border-[#25D366]"
                    );
                    confirmBtn.setAttribute(
                        "href",
                        destinationUrl || waGenelHref,
                    );
                    confirmBtn.setAttribute("target", "_blank");
                    confirmBtn.setAttribute("rel", "noopener noreferrer");
                } else {
                    confirmBtn.innerHTML = `
                        <div class="flex items-center gap-2">
                        <svg class="w-6 h-6 phone-ring" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                        EVET, İSTANBUL VEYA GEBZE'DEYİM
                        </div>
                    `;
                    confirmBtn.classList.remove(
                        "bg-[#25D366]",
                        "hover:bg-[#128C7E]",
                        "shadow-[0_5px_20px_rgba(37,211,102,0.4)]",
                        "border",
                        "border-[#25D366]"
                    );
                    confirmBtn.classList.add(
                        "bg-green-600",
                        "hover:bg-green-700",
                        "shadow-[0_5px_20px_rgba(22,163,74,0.4)]",
                        "border",
                        "border-green-500",
                    );
                    confirmBtn.setAttribute(
                        "href",
                        destinationUrl || phoneHref,
                    );
                    confirmBtn.removeAttribute("target");
                    confirmBtn.removeAttribute("rel");
                }
            }

            modal.classList.remove("hidden");
            void modal.offsetWidth;
            backdrop.classList.remove("opacity-0");
            content.classList.remove("scale-90", "opacity-0");
            content.classList.add("scale-100", "opacity-100");
            document.body.style.overflow = "hidden";

            modalHistoryPushed = true;
            window.history.pushState({ modalOpen: true }, "");

            trackEvent("region_modal_opened", {
                source,
                location: currentLocation,
                ...currentMeta,
            });

            if (!currentMeta.intent_tracked) {
                trackEvent(
                    source === "phone" ? "phone_intent" : "whatsapp_intent",
                    {
                        ...currentMeta,
                        location: currentLocation,
                        scroll_depth_pct: getScrollDepthPct(),
                    },
                );
            }

            // Backward compatibility events
            trackEvent(
                source === "phone" ? "tel_arama_niyeti" : "whatsapp_niyeti",
                { location: currentLocation, ...currentMeta },
            );
        }

        window.openServiceRegionModal = openModal;

        function closeModal() {
            const m = document.getElementById("region-modal");
            const bd = document.getElementById("modal-backdrop");
            const ct = document.getElementById("modal-content");
            if (!m || !bd || !ct) return;
            bd.classList.add("opacity-0");
            ct.classList.remove("scale-100", "opacity-100");
            ct.classList.add("scale-90", "opacity-0");
            setTimeout(() => {
                m.classList.add("hidden");
                document.body.style.overflow = "";
            }, 300);
        }

        window.addEventListener("popstate", (e) => {
            // Push state again to block back-button modal bypass.
            if (
                modal &&
                !modal.classList.contains("hidden") &&
                modalHistoryPushed
            ) {
                window.history.pushState({ modalOpen: true }, "");
            }
        });

        triggerPhone?.addEventListener("click", (e) => {
            e.preventDefault();
            openModal("phone", triggerPhone.href, "quick_action_hub", {
                cta_position: "sticky",
                cta_variant: "v1",
                scroll_depth_pct: getScrollDepthPct(),
            });
        });

        triggerWhatsapp?.addEventListener("click", (e) => {
            e.preventDefault();
            openModal("whatsapp", triggerWhatsapp.href, "quick_action_hub", {
                cta_position: "sticky",
                cta_variant: "v2",
                scroll_depth_pct: getScrollDepthPct(),
            });
        });


        rejectBtn?.addEventListener("click", () => dismissModalByChoice("out_of_scope"));
        // Backdrop click intentionally disabled — modal requires an explicit choice.

        confirmBtn?.addEventListener("click", () => {
            setQualifiedSession();
            trackEvent("region_filter_passed", {
                source: currentAction,
                location: currentLocation,
                ...currentMeta,
            });
            trackQualifiedContact(currentAction, currentLocation, "modal", currentMeta);
            setTimeout(closeModal, 1000);
        });

        // Time logic: Primary by hour
        function applyPrimaryByHour() {
            if (!triggerPhone || !triggerWhatsapp) return;
            const slot = getHourSlot();
            const isBusinessHours =
                slot === "open_morning" || slot === "open_evening";
            const isClosed = slot === "pre_open" || slot === "after_hours";

            triggerPhone.classList.remove(
                "hub-primary",
                "hub-primary-phone",
                "hub-secondary",
            );
            triggerWhatsapp.classList.remove(
                "hub-primary",
                "hub-primary-whatsapp",
                "hub-secondary",
            );
            triggerPhone.classList.toggle("hidden", isClosed);

            const phoneText = triggerPhone.querySelector(".hub-text-open");

            if (isBusinessHours) {
                triggerPhone.classList.add("hub-primary", "hub-primary-phone");
                triggerWhatsapp.classList.add("hub-secondary");
                if (phoneText) phoneText.textContent = "HEMEN ARA";
            } else if (!isClosed) {
                triggerWhatsapp.classList.add(
                    "hub-primary",
                    "hub-primary-whatsapp",
                );
                triggerPhone.classList.add("hub-secondary");
                if (phoneText) phoneText.textContent = "SABAH İÇİN ARA";
            }

            if (isClosed) {
                triggerPhone.classList.add("opacity-50", "grayscale");
                triggerWhatsapp.classList.add("opacity-50", "grayscale");
                if (phoneText) phoneText.textContent = "KAPALIYIZ";
                
                triggerPhone.addEventListener("click", (e) => {
                    e.preventDefault();
                    e.stopImmediatePropagation();
                    alert("Şu an hizmet saatleri dışındayız. Lütfen 08:30 - 18:00 saatleri aralığında iletişime geçin.");
                });
                
                triggerWhatsapp.addEventListener("click", (e) => {
                    e.preventDefault();
                    e.stopImmediatePropagation();
                    alert("Şu an hizmet saatleri dışındayız. Lütfen 08:30 - 18:00 saatleri aralığında iletişime geçin.");
                });
            }

            return { isBusinessHours, isClosed, slot };
        }

        const { isBusinessHours, isClosed, slot } = applyPrimaryByHour() || { isBusinessHours: true, isClosed: false, slot: "open_morning" };

        // Tooltip system
        const tooltip = document.getElementById("hub-tooltip");
        const tooltipText = document.getElementById("tooltip-text");
        const slotMessageHelper = window.__tetikSlotMessage;
        
        const slotPrimaryMessage =
            typeof slotMessageHelper === "function"
                ? slotMessageHelper()
                : isClosed
                  ? "Mesai Saatleri: 08:30 - 18:00"
                  : isBusinessHours
                    ? "Su an: Hizli baglanti saati"
                    : "Su an: Yarin planlamasi acik";
        const activePhrases = isClosed 
            ? [
                "Şu An Kapalıyız",
                "Mesai Saatleri: 08:30 - 18:00"
              ]
            : isBusinessHours
            ? [
                  "Hemen Ara - 30 sn'de bağlan",
                  "WhatsApp'tan Fiyat Al",
                  slotPrimaryMessage,
              ]
            : [
                  "WhatsApp'tan Yaz - Sabah dönelim",
                  slotPrimaryMessage,
                  "Tuzla - Gebze Ozel Servis",
              ];

        function showTooltip(index, duration = 3000) {
            if (!tooltip || !tooltipText) return;
            tooltipText.textContent = activePhrases[index];
            tooltip.classList.remove("opacity-0", "translate-y-4");
            tooltip.classList.add("opacity-100", "translate-y-0");
            setTimeout(() => {
                tooltip.classList.add("opacity-0", "translate-y-4");
                tooltip.classList.remove("opacity-100", "translate-y-0");
            }, duration);
        }

        setTimeout(() => showTooltip(0), 10000);
        setTimeout(() => showTooltip(1), 21000);
        setTimeout(() => showTooltip(2), 46000);

        // Scroll glow
        let glowFired = false;
        window.addEventListener(
            "scroll",
            () => {
                if (glowFired) return;
                const scrollPercent =
                    window.scrollY /
                    (document.documentElement.scrollHeight -
                        window.innerHeight);
                if (scrollPercent > 0.6) {
                    glowFired = true;
                    const primaryBtn = isBusinessHours
                        ? triggerPhone
                        : triggerWhatsapp;
                    if (primaryBtn) {
                        primaryBtn.classList.add("glow-burst");
                        setTimeout(
                            () => primaryBtn.classList.remove("glow-burst"),
                            600,
                        );
                    }
                }
            },
            { passive: true },
        );

        // Conflict detection: hide sticky hub when another CTA block is on screen
        const conflictTargets = document.querySelectorAll(
            "[data-sticky-conflict]",
        );
        if (hubContainer && conflictTargets.length > 0) {
            const conflictObserver = new IntersectionObserver(
                (entries) => {
                    const hasVisibleConflict = entries.some(
                        (entry) => entry.isIntersecting,
                    );
                    hubContainer.classList.toggle(
                        "is-conflicted",
                        hasVisibleConflict,
                    );
                },
                { threshold: 0.2 },
            );
            conflictTargets.forEach((target) =>
                conflictObserver.observe(target),
            );
        }
    }

    initQuickActionHub();
    document.addEventListener("astro:page-load", initQuickActionHub);
</script>

<style>
    #quick-action-hub-mobile.force-hidden {
        display: none !important;
    }

    #quick-action-hub-mobile.is-conflicted {
        opacity: 0;
        pointer-events: none;
        transform: translateY(18px);
        transition:
            opacity 0.3s ease,
            transform 0.3s ease;
    }

    /* v2: GPU Pulse */
    .hub-primary::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        z-index: -1;
    }
    .hub-primary-phone::after {
        background-color: rgba(245, 158, 11, 0.4);
        animation: pulse-ring-gpu 2.8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    .hub-primary-whatsapp::after {
        background-color: rgba(37, 211, 102, 0.4);
        animation: pulse-ring-gpu 2.8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        animation-delay: 0.5s;
    }

    @keyframes pulse-ring-gpu {
        0% {
            transform: scale(1);
            opacity: 0.8;
        }
        80%,
        100% {
            transform: scale(1.6);
            opacity: 0;
        }
    }

    .hub-primary {
        transform: scale(1.06);
        opacity: 1;
    }
    .hub-secondary {
        transform: scale(1);
        opacity: 0.88;
    }

    @keyframes glow-burst-anim {
        0% {
            transform: scale(1);
            filter: brightness(1);
        }
        50% {
            transform: scale(1.15);
            filter: brightness(1.3);
        }
        100% {
            transform: scale(1);
            filter: brightness(1);
        }
    }
    .glow-burst {
        animation: glow-burst-anim 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
    }

    @keyframes phone-ring-animation {
        0% {
            transform: rotate(0);
        }
        5% {
            transform: rotate(15deg);
        }
        10% {
            transform: rotate(-15deg);
        }
        15% {
            transform: rotate(15deg);
        }
        20% {
            transform: rotate(-15deg);
        }
        25% {
            transform: rotate(10deg);
        }
        30% {
            transform: rotate(-10deg);
        }
        100% {
            transform: rotate(0);
        }
    }
    .phone-ring {
        animation: phone-ring-animation 4s infinite;
    }
    .no-underline {
        text-decoration: none !important;
    }
</style>


