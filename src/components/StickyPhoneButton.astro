---
import { serviceScope } from "../lib/serviceScope";

interface Props {
    showTooltips?: boolean;
    onlyFirstVisit?: boolean;
}

const { showTooltips = true, onlyFirstVisit = true } = Astro.props;
const phoneNumber = serviceScope.phone;
const whatsappNumber = serviceScope.whatsappNumber;
const whatsappMessage = encodeURIComponent(
    "Merhaba, araç servisi hakkında bilgi almak istiyorum",
);
---

<div
    class="sticky-contact-wrapper"
    data-tooltips={showTooltips}
    data-first-visit={onlyFirstVisit}
>
    <!-- Telefon Butonu (Ustte) -->
    <a
        href={`tel:${phoneNumber}`}
        class="sticky-btn sticky-phone-btn"
        aria-label="Hemen Ara"
        title="Hemen Ara"
        data-btn-type="phone"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="#ffffff"
            stroke="none"
        >
            <path
                fill-rule="evenodd"
                d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z"
                clip-rule="evenodd"></path>
        </svg>
        <span class="btn-tooltip phone-tooltip" aria-hidden="true"></span>
    </a>

    <!-- WhatsApp Butonu (Altta) -->
    <a
        href={`https://wa.me/${whatsappNumber}?text=${whatsappMessage}`}
        class="sticky-btn sticky-whatsapp-btn"
        aria-label="WhatsApp ile iletisime gec"
        title="WhatsApp'tan yazin"
        target="_blank"
        rel="noopener noreferrer"
        data-btn-type="whatsapp"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="#ffffff"
        >
            <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
        </svg>
        <span class="btn-tooltip whatsapp-tooltip" aria-hidden="true"></span>
    </a>
</div>

<script>
    function initContactTooltips() {
        const wrapper = document.querySelector(
            ".sticky-contact-wrapper",
        ) as HTMLElement;
        if (!wrapper) return;

        const showTooltips = wrapper.dataset.tooltips === "true";
        const onlyFirstVisit = wrapper.dataset.firstVisit === "true";
        const whatsappTooltip = wrapper.querySelector(
            ".whatsapp-tooltip",
        ) as HTMLElement;
        const phoneTooltip = wrapper.querySelector(
            ".phone-tooltip",
        ) as HTMLElement;

        // GA4 tracking for desktop sticky buttons
        const phoneBtn = wrapper.querySelector(".sticky-phone-btn");
        const whatsappBtn = wrapper.querySelector(".sticky-whatsapp-btn");
        const trackHelper = (window as any).__tetikTrackEvent;
        const shouldDeferIntentToModal = () =>
            typeof sessionStorage !== "undefined" &&
            sessionStorage.getItem("region_modal_qualified") !== "true" &&
            typeof (window as any).openServiceRegionModal === "function";

        phoneBtn?.addEventListener("click", (e) => {
            if (shouldDeferIntentToModal()) {
                e.preventDefault();
                (window as any).openServiceRegionModal(
                    "phone",
                    (phoneBtn as HTMLAnchorElement).href,
                    "desktop_sticky",
                    { cta_position: "sticky_left" },
                );
                return;
            }
            if (typeof trackHelper === "function") {
                trackHelper("tel_arama_niyeti", {
                    location: "desktop_sticky",
                });
            } else if (typeof (window as any).gtag === "function") {
                (window as any).gtag("event", "tel_arama_niyeti", {
                    location: "desktop_sticky",
                });
            }
        });

        whatsappBtn?.addEventListener("click", (e) => {
            if (shouldDeferIntentToModal()) {
                e.preventDefault();
                (window as any).openServiceRegionModal(
                    "whatsapp",
                    (whatsappBtn as HTMLAnchorElement).href,
                    "desktop_sticky",
                    { cta_position: "sticky_left" },
                );
                return;
            }
            if (typeof trackHelper === "function") {
                trackHelper("whatsapp_niyeti", {
                    location: "desktop_sticky",
                });
            } else if (typeof (window as any).gtag === "function") {
                (window as any).gtag("event", "whatsapp_niyeti", {
                    location: "desktop_sticky",
                });
            }
        });

        if (!showTooltips || !whatsappTooltip) return;

        // localStorage kontrolu
        const storageKey = "contact_tooltips_shown_v2";
        if (onlyFirstVisit && localStorage.getItem(storageKey)) return;

        // Zamanlama ayarlari
        const timings = {
            first: 3000,
            duration: 4000,
        };

        // Mesajlar
        const messages = {
            first: {
                text: "👋 Size nasıl yardımcı olabiliriz?",
                target: "whatsapp",
            },
            phone: { text: "📞 Hemen arayın", target: "phone" },
            footer: { text: "💬 Hemen fiyat alın", target: "whatsapp" },
        };

        let footerShown = false;

        // Tooltip gosterme fonksiyonu
        function showTooltipEl(
            tooltip: HTMLElement,
            text: string,
            duration: number,
        ) {
            tooltip.textContent = text;
            tooltip.classList.add("visible");
            setTimeout(() => tooltip.classList.remove("visible"), duration);
        }

        // Ilk tooltip (WhatsApp)
        setTimeout(() => {
            if (!footerShown) {
                showTooltipEl(
                    whatsappTooltip,
                    messages.first.text,
                    timings.duration,
                );
            }
        }, timings.first);

        // Ikinci tooltip (Telefon) - 8 saniye sonra
        setTimeout(() => {
            if (!footerShown && phoneTooltip) {
                showTooltipEl(
                    phoneTooltip,
                    messages.phone.text,
                    timings.duration,
                );
            }
        }, 8000);

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    const stickyWrapper = document.querySelector(
                        ".sticky-contact-wrapper",
                    );
                    if (entry.isIntersecting) {
                        stickyWrapper?.classList.add("near-footer");

                        if (!footerShown) {
                            footerShown = true;
                            showTooltipEl(
                                whatsappTooltip,
                                messages.footer.text,
                                timings.duration,
                            );
                        }
                    } else {
                        stickyWrapper?.classList.remove("near-footer");
                    }
                });
            },
            { threshold: 0.1 },
        );

        const footer = document.querySelector("footer");
        if (footer) observer.observe(footer);

        const conflictTargets = document.querySelectorAll(
            "[data-sticky-conflict]",
        );
        if (conflictTargets.length > 0) {
            const conflictObserver = new IntersectionObserver(
                (entries) => {
                    const stickyWrapper = document.querySelector(
                        ".sticky-contact-wrapper",
                    );
                    const hasVisibleConflict = entries.some(
                        (entry) => entry.isIntersecting,
                    );
                    stickyWrapper?.classList.toggle(
                        "conflict-hidden",
                        hasVisibleConflict,
                    );
                },
                { threshold: 0.2 },
            );
            conflictTargets.forEach((target) =>
                conflictObserver.observe(target),
            );
        }

        // Scroll Opacity Logic
        window.addEventListener(
            "scroll",
            () => {
                const stickyWrapper = document.querySelector(
                    ".sticky-contact-wrapper",
                );
                if (window.scrollY > 100) {
                    stickyWrapper?.classList.add("scrolled");
                } else {
                    stickyWrapper?.classList.remove("scrolled");
                }
            },
            { passive: true },
        );

        // Ä°lk ziyaret olarak iÅŸaretle
        if (onlyFirstVisit) {
            localStorage.setItem(storageKey, "true");
        }
    }

    // Init
    if (document.readyState === "complete") {
        setTimeout(initContactTooltips, 100);
    } else {
        window.addEventListener(
            "load",
            () => {
                setTimeout(initContactTooltips, 100);
            },
            { once: true },
        );
    }
    document.addEventListener("astro:page-load", () => {
        setTimeout(initContactTooltips, 100);
    });
</script>

<style>
    .sticky-contact-wrapper {
        position: fixed;
        right: 20px;
        bottom: 20px;
        z-index: 9999;
        display: none; /* Mobilde gizli, Aksiyon Merkezi ile Ã§akÄ±ÅŸmayÄ± Ã¶nlemek iÃ§in */
        flex-direction: column;
        gap: 10px;
        opacity: 0.85; /* v2: 0.6 â†’ 0.85 â€” daha gÃ¼venilir gÃ¶rÃ¼nÃ¼m */
        transition:
            opacity 0.3s ease,
            transform 0.3s ease;
    }

    /* Scroll sonrasÄ± veya hover'da tam opaklÄ±k */
    .sticky-contact-wrapper.scrolled,
    .sticky-contact-wrapper:hover {
        opacity: 1;
    }

    /* Footer'a yaklaÅŸÄ±nca soluklaÅŸtÄ±r (v2: opacity 0 â†’ 0.3, tamamen kaybolmaz) */
    .sticky-contact-wrapper.near-footer {
        opacity: 0.3;
        pointer-events: none;
        transform: translateY(10px);
    }

    .sticky-contact-wrapper.conflict-hidden {
        opacity: 0;
        pointer-events: none;
        transform: translateY(12px);
    }

    /* Desktop'ta sol altta ve gÃ¶rÃ¼nÃ¼r â€” fixed desktop bar'Ä±n Ã¼stÃ¼nde */
    @media (min-width: 768px) {
        .sticky-contact-wrapper {
            display: flex;
            left: 20px;
            right: auto;
            bottom: 110px;
        }
    }

    .sticky-btn {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 64px;
        height: 64px;
        border-radius: 50%;
        box-shadow: 0 8px 32px -8px rgba(0, 0, 0, 0.5); /* v2: daha derin gÃ¶lge */
        transition: all 0.3s ease;
        color: #ffffff;
        text-decoration: none;
        position: relative;
    }

    .sticky-btn:hover {
        transform: scale(1.1);
        box-shadow: 0 10px 36px -6px rgba(0, 0, 0, 0.55);
    }

    .sticky-btn svg {
        width: 28px;
        height: 28px;
    }

    /* Telefon Butonu */
    .sticky-phone-btn {
        background-color: #f59e0b; /* amber-500 */
    }

    .sticky-phone-btn:hover {
        background-color: #d97706; /* amber-600 */
    }

    /* WhatsApp Button */
    .sticky-whatsapp-btn {
        background-color: #25d366;
    }

    .sticky-whatsapp-btn:hover {
        background-color: #20bd5a;
    }

    /* Tooltips - Desktop saÄŸa aÃ§Ä±lÄ±r */
    .btn-tooltip {
        position: absolute;
        left: 74px;
        right: auto;
        top: 50%;
        transform: translateY(-50%) translateX(-10px);
        background: #1e293b;
        color: #fff;
        padding: 10px 16px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        white-space: nowrap;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
        pointer-events: none;
    }

    .btn-tooltip::before {
        content: "";
        position: absolute;
        left: -6px;
        right: auto;
        top: 50%;
        transform: translateY(-50%);
        border: 6px solid transparent;
        border-right-color: #1e293b;
        border-left: none;
    }

    .btn-tooltip.visible {
        opacity: 1;
        visibility: visible;
        transform: translateY(-50%) translateX(0);
    }

    /* v2: GPU-only Pulse (Pseudo-element + transform + opacity) */
    .sticky-btn::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 50%;
        z-index: -1;
    }

    @keyframes pulse-ring-gpu-sticky {
        0% {
            transform: scale(1);
            opacity: 0.6;
        }
        80%,
        100% {
            transform: scale(1.5);
            opacity: 0;
        }
    }

    .sticky-phone-btn::after {
        background-color: rgba(245, 158, 11, 0.5);
        animation: pulse-ring-gpu-sticky 2.5s cubic-bezier(0.4, 0, 0.6, 1)
            infinite;
        animation-delay: 1s;
    }

    .sticky-whatsapp-btn::after {
        background-color: rgba(37, 211, 102, 0.5);
        animation: pulse-ring-gpu-sticky 2s cubic-bezier(0.4, 0, 0.6, 1)
            infinite;
        animation-delay: 0.5s;
    }
</style>
